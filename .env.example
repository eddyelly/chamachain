# Deployer key for Fuji (account index 0, also the Mwenyekiti / chair member).
# Get test AVAX from the faucet: https://faucet.avax.network/ (select Fuji C-Chain)
PRIVATE_KEY=0xyour_deployer_private_key_here

# Mnemonic used to derive the five demo member accounts (indexes 0..4).
# Account 0 must match PRIVATE_KEY above so the deployer is also member 1 (Mwenyekiti).
# Use a throwaway mnemonic for the demo only. Never reuse a mainnet mnemonic.
DEMO_MNEMONIC="test test test test test test test test test test test junk"

# Fuji RPC (public endpoint, override if you have a private one)
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
